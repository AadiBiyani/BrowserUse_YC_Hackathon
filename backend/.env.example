# ============================================================
# ReplayBench - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ------ Browser Use ------
# Only needed if using Browser Use Cloud (browser-use-sdk) as a fallback.
# We primarily use the open-source browser-use library (no key required).
# Claim $100 credits: https://cloud.browser-use.com → use hackathon claim form
BROWSER_USE_API_KEY=your_browser_use_key_here

# ------ LLM Providers ------
# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY_HERE

# Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_ANTHROPIC_KEY_HERE

# Google Gemini (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=YOUR_GOOGLE_KEY_HERE

# ------ Observability ------
# Laminar (https://laminar.sh → Settings → API Keys)
LAMINAR_API_KEY=your_laminar_key_here

# ------ Evaluation ------
# HUD (https://hud.ai/billing → use code YCHACKATHON)
HUD_API_KEY=your_hud_key_here

# ------ Raw Trace Archive ------
# MongoDB Atlas connection string (free M0 cluster is sufficient)
# Create at: https://cloud.mongodb.com → free tier → get connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# ------ Semantic Memory / RAG ------
# Supermemory API key (https://supermemory.ai → Settings → API Keys)
SUPERMEMORY_API_KEY=your_supermemory_key_here

# ------ Backend ------
# Convex HTTP Actions URL — your deployment
CONVEX_SITE_URL=https://your-deployment.convex.site

# Convex deployment URL — your deployment
CONVEX_URL=https://your-deployment.convex.cloud

# ------ App Config ------
# Directory for storing HAR files locally before uploading to Convex
HAR_OUTPUT_DIR=./runs

# Default model to use for benchmarking (gpt-4o | claude-3-5-sonnet-20241022 | gemini-2.0-flash)
DEFAULT_MODEL=gpt-4o
